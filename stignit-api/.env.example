# =============================================================================
# Stignit API — environment template.
# Copy to `.env` for local dev. NEVER commit real secrets (PRD 11.5).
# In production these come from a secrets manager, not a file.
# =============================================================================

NODE_ENV=development
PORT=3000
API_VERSION=v1

# --- Primary Postgres (writes) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=stignit
DB_PASSWORD=stignit_local_dev
DB_NAME=stignit

# --- Read replica (reads); falls back to primary if unset (PRD 7.2 replication) ---
DB_REPLICA_HOST=
DB_REPLICA_PORT=5432

# --- Redis (OTP, rate limit, token blacklist, event bus streams, BullMQ, GEO) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Field-level encryption (PRD 11.1). 32-byte keys, base64-encoded. ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
FIELD_ENCRYPTION_KEY=
# Optional: previous key kept to decrypt during key rotation.
FIELD_ENCRYPTION_KEY_PREVIOUS=
# Separate HMAC key for deterministic blind indexes (phone lookup while encrypted).
BLIND_INDEX_KEY=

# --- JWT (PRD 11.2) ---
JWT_ACCESS_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_TTL=30d

# --- Admin dashboard SSO (separate from mobile auth, PRD 11.2) ---
ADMIN_SSO_ISSUER=https://accounts.google.com
ADMIN_SSO_CLIENT_ID=
ADMIN_SSO_ALLOWED_DOMAIN=stignit.ng

# --- External integrations (PRD 8.1, 10.3) — placeholders, no real keys in repo ---
# Sendchamp: all outbound SMS, including OTP delivery.
SENDCHAMP_API_KEY=
SENDCHAMP_SENDER_NAME=Sendchamp
FCM_PROJECT_ID=
GOOGLE_MAPS_API_KEY=
# AI provider is OQ05 (unresolved). Default adapter is Anthropic Claude.
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-5
