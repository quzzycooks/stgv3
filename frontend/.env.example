# Base URL of the running stignit-api instance (no trailing slash, no /v1 suffix)
VITE_API_BASE_URL=http://localhost:3000

# Same host, used for the Socket.IO /rt namespace
VITE_WS_URL=http://localhost:3000

# Optional — enables a live Mapbox map on the map screens. Without it, a
# styled placeholder renders instead so the app runs with zero secrets.
# Get a free token at https://account.mapbox.com/access-tokens/ (no billing
# card required for the free tier).
VITE_MAPBOX_TOKEN=
